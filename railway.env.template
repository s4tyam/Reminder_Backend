# ============================================================
#  RAILWAY ENVIRONMENT VARIABLES — Reminder App Backend
#  Paste each of these in Railway → your service → Variables
# ============================================================

# ── Database (auto-filled by Railway PostgreSQL plugin) ──
# Railway sets this automatically when you add the Postgres plugin:
DATABASE_URL=postgresql://${{Postgres.PGUSER}}:${{Postgres.PGPASSWORD}}@${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}

# ── Spring datasource (Railway injects DATABASE_URL, but Spring needs these) ──
SPRING_DATASOURCE_URL=jdbc:postgresql://${PGHOST}:${PGPORT}/${PGDATABASE}
SPRING_DATASOURCE_USERNAME=${PGUSER}
SPRING_DATASOURCE_PASSWORD=${PGPASSWORD}

